# Copy to `.env` and fill in. Never commit `.env` — add it to `.gitignore`.
# Load values into your Python with `python-dotenv` or `source .env` before
# running orchestrate CLI commands.

# -----------------------------------------------------------------------------
# Hosted Orchestrate instance (deploy_recipe.md + remote_setup.md)
# Provided by the hackathon organizer.
# -----------------------------------------------------------------------------
WO_ENV_NAME=hackathon       # local alias you'll use with `orchestrate env activate`
WO_INSTANCE_URL=            # e.g. https://api.staging-wa.watson-orchestrate.ibm.com/instances/<uuid>
WO_INSTANCE_API_KEY=        # MCSP-format key, usually starts with k1:usr_...

# --- IAM endpoint and auth type ---
# Production instances: leave both empty (CLI defaults are correct).
# Staging  (staging-wa.watson-orchestrate.ibm.com):
#   WO_IAM_URL=https://iam.platform.test.saas.ibm.com
#   WO_AUTH_TYPE=mcsp_v1
# Pre-prod (*.test.cloud.ibm.com):
#   WO_IAM_URL=https://account-iam.platform.test.saas.ibm.com
#   WO_AUTH_TYPE=mcsp_v2
# See remote_setup.md for the full tier table and a curl diagnostic.
WO_IAM_URL=
WO_AUTH_TYPE=

# -----------------------------------------------------------------------------
# Example app credentials, referenced by connection YAMLs as `{MY_APP[...]}`.
# Add one block per external API your tool calls.
# -----------------------------------------------------------------------------
MY_APP_TOKEN=
# MY_APP_USERNAME=
# MY_APP_PASSWORD=
# MY_OAUTH_APP_CLIENT_ID=
# MY_OAUTH_APP_CLIENT_SECRET=
# MY_OAUTH_APP_TOKEN_URL=
# MY_OAUTH_APP_AUTH_URL=
